# Backend API base URL
# Vue dev server (5173) → Spring backend (8080) 직접 호출.
# CORS 는 backend 의 libra.cors.allowed-origins 에 5173 이 등록돼 있어야 함.
VITE_API_BASE_URL=http://localhost:8080

# 4차원 메트릭 mock 토글
# - true (기본): 프론트 mock 데이터 사용 (백엔드 GET /api/runs/:threadId/metrics 미연결 동안)
# - false: 실제 백엔드 호출
VITE_METRICS_USE_MOCK=true
